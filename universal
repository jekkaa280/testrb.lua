local function createTeleportScreenButton()
    if teleportScreenButton then
        teleportScreenButton:Destroy()
    end
    
    teleportScreenButton = Instance.new("TextButton")
    teleportScreenButton.Name = "TeleportScreenButton"
    teleportScreenButton.Size = UDim2.new(0, 60, 0, 60) -- Уменьшил размер
