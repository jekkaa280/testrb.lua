-- ========== AUTO SHOOT ==========
local function findWeapon()
    local character = player.Character
    if not character then return nil end
    
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            local name = string.lower(tool.Name)
            if name:find("mp5") or name:find("мр5") or name:find("gun") or name:find("rifle") or name:find("pistol") then
                return tool
            end
        end
    end
    return nil
end

local function performShootAtEnemy()
    local now = tick()
    if now - lastShot < shootCooldown then return false end
    
    if not shootRemote then
        return false
    end
    
    local weapon = findWeapon()
    if not weapon then
        return false
    end
    
    local enemy = nil
    if settings.pursuit then
        enemy = getPursuitTarget()
    end
    
    if not enemy then
        enemy = findClosestEnemy()
    end
    
    if not enemy then
        return false
    end
    
    local character = player.Character
    if not character then return false end
    
    pcall(function()
        weapon:Activate()
        
        local viewportSize = Workspace.CurrentCamera.ViewportSize
        VirtualInputManager:SendMouseButtonEvent(
            viewportSize.X / 2,
            viewportSize.Y / 2,
            0,
            true,
            game,
            1
        )
        
        task.wait(0.02)
        
        VirtualInputManager:SendMouseButtonEvent(
            viewportSize.X / 2,
            viewportSize.Y / 2,
            0,
            false,
            game,
            1
        )
    end)
    
    lastShot = now
    return true
end

