    teleportScreenButton.Font = Enum.Font.GothamBold
    teleportScreenButton.TextSize = 24
    teleportScreenButton.Visible = true
    teleportScreenButton.ZIndex = 9998
    teleportScreenButton.Parent = screenGui
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 15)
    buttonCorner.Parent = teleportScreenButton
    
    local buttonStroke = Instance.new("UIStroke")
    buttonStroke.Color = Color3.fromRGB(255, 255, 255)
    buttonStroke.Thickness = 2
    buttonStroke.Parent = teleportScreenButton
    
    -- ИСПРАВЛЕНИЕ: Разделяем перетаскивание и нажатие
    local dragging = false
    local dragInput, dragStart, startPos
    
    teleportScreenButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Если клик короткий - это телепорт
            if not dragging then
                local clickTime = tick()
                local startPos = input.Position
                
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        local endPos = input.Position
                        local moveDistance = (endPos - startPos).Magnitude
                        local clickDuration = tick() - clickTime
                        
                        -- Если перемещение маленькое и время короткое - это клик для телепорта
                        if moveDistance < 10 and clickDuration < 0.3 then
                            teleportForward()
                        end
                        
                        dragging = false
                        teleportScreenButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
                    end
                end)
            end
        end
    end)
    
    -- Отдельный обработчик для начала перетаскивания
    teleportScreenButton.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragInput.UserInputState == Enum.UserInputState.Change then
            if not dragging then
                dragging = true
                dragStart = input.Position
                startPos = teleportScreenButton.Position
                teleportScreenButton.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
            else
                local delta = input.Position - dragStart
                local newPosition = UDim2.new(
                    startPos.X.Scale, 
                    startPos.X.Offset + delta.X,
                    startPos.Y.Scale, 
                    startPos.Y.Offset + delta.Y
                )
                
                -- Ограничиваем перемещение в пределах экрана
                local viewportSize = screenGui.AbsoluteSize
                local buttonSize = teleportScreenButton.AbsoluteSize
                
                local minX = 0
                local maxX = viewportSize.X - buttonSize.X
                local minY = 0
                local maxY = viewportSize.Y - buttonSize.Y
                
                local absoluteX = startPos.X.Offset + delta.X
                local absoluteY = startPos.Y.Offset + delta.Y
                
                absoluteX = math.clamp(absoluteX, minX, maxX)
                absoluteY = math.clamp(absoluteY, minY, maxY)
                
                teleportScreenButton.Position = UDim2.new(0, absoluteX, 0, absoluteY)
            end
        end
    end)
    
    -- Сбрасываем состояние перетаскивания при отпускании
    UserInputService.InputEnded:Connect(function(input)
        if input == dragInput then
            dragging = false
            teleportScreenButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
        end
    end)
    
    print("[Teleport] Улучшенная экранная кнопка создана")
end

