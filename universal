-- ========== ESP ==========
local function updateESP()
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and not espHighlights[otherPlayer] then
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESP_" .. otherPlayer.Name
            highlight.FillColor = isEnemy(otherPlayer) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
            highlight.FillTransparency = 0.7
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.OutlineTransparency = 0
            highlight.Adornee = otherPlayer.Character
            highlight.Parent = Workspace
            
            espHighlights[otherPlayer] = highlight
        end
    end
    
    for playerObj, highlight in pairs(espHighlights) do
        if playerObj and playerObj.Character and highlight then
            highlight.Adornee = playerObj.Character
            highlight.FillColor = isEnemy(playerObj) and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(50, 255, 50)
        elseif highlight then
            highlight:Destroy()
            espHighlights[playerObj] = nil
        end
    end
end

