-- ========== ОБЩИЕ ФУНКЦИИ ==========
local function isEnemy(otherPlayer)
    if otherPlayer == player then return false end
    if player.Team and otherPlayer.Team then
        return player.Team ~= otherPlayer.Team
    end
    return true -- Если нет команд, считаем всех врагами
end

local function findClosestEnemy()
    local character = player.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local myPos = rootPart.Position
    local closest = nil
    local closestDist = math.huge
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if isEnemy(otherPlayer) and otherPlayer.Character then
            local enemyRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
            local enemyHumanoid = otherPlayer.Character:FindFirstChildOfClass("Humanoid")
            
            if enemyRoot and enemyHumanoid and enemyHumanoid.Health > 0 then
                local dist = (myPos - enemyRoot.Position).Magnitude
                if dist < closestDist and dist <= autoAimDistance then -- Проверяем расстояние
                    closestDist = dist
                    closest = otherPlayer
                end
            end
        end
    end
    
    return closest
end

-- ========== НАСТРОЕННЫЙ ТРАССЕР АВТОАИМА ==========
local function updateAutoAimTracer()
    if not settings.autoaim then
        if autoAimLine then
            autoAimLine:Destroy()
            autoAimLine = nil
        end
        return
    end

    local character = player.Character
    if not character then return end

    local enemy = findClosestEnemy()
    if not enemy or not enemy.Character then
        if autoAimLine then
            autoAimLine:Destroy()
            autoAimLine = nil
        end
        return
    end

    local myRoot = character:FindFirstChild("HumanoidRootPart")
    local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot or not enemyRoot then return end

    -- создаём Part-трассер, если нет
    if not autoAimLine then
        autoAimLine = Instance.new("Part")
        autoAimLine.Name = "AutoAimTracer"
        autoAimLine.Anchored = true
        autoAimLine.CanCollide = false
        autoAimLine.Material = Enum.Material.Neon
        autoAimLine.Color = Color3.fromRGB(255, 50, 50)
        autoAimLine.Size = Vector3.new(0.5, 0.5, 0.5)
        autoAimLine.Transparency = 0.4
        autoAimLine.Parent = Workspace
    end

    -- дистанция до цели
    local dist = (myRoot.Position - enemyRoot.Position).Magnitude

    -- расчёт CFrame трассы
    local beamCF = CFrame.new(myRoot.Position, enemyRoot.Position)
    local beamSize = Vector3.new(0.2, 0.2, dist)

    -- ПОМЕШАТЬ СТОЛЬКО, ЧТОБЫ ЛИНИЯ БЫЛА ЖИРНЕЕ
    autoAimLine.Size = Vector3.new(0.15, 0.15, dist) -- размер линии
    autoAimLine.CFrame = beamCF * CFrame.new(0, 0, -dist/2)
    autoAimLine.Color = Color3.fromRGB(180, 0, 255) -- яркий цвет

end

-- ========== ФУНКЦИЯ ОПРЕДЕЛЕНИЯ РЕЖИМА КАМЕРЫ ==========
local function getCameraMode()
    local camera = Workspace.CurrentCamera
    if not camera then return "thirdperson" end
    
    -- Проверяем, к чему привязана камера
    local cameraSubject = camera.CameraSubject
    
    if cameraSubject and cameraSubject:IsA("Humanoid") then
        -- Проверяем расстояние до персонажа
        local character = cameraSubject.Parent
        if character then
            local distance = (camera.CFrame.Position - character:GetPivot().Position).Magnitude
            
            if distance < 5 then
                return "firstperson"
            else
                return "thirdperson"
            end
        end
    end
    
    return "thirdperson"
end

-- ========== AUTO AIM С РЕЖИМАМИ (УСКОРЕННЫЙ) ==========
local function startAutoAim()
    if connections.autoaim then 
        connections.autoaim:Disconnect()
        connections.autoaim = nil
    end
    
    print("[Auto Aim] ✅ Активирован (Режим: " .. autoAimMode .. ", Дистанция: " .. autoAimDistance .. " studs)")
    
    connections.autoaim = RunService.Heartbeat:Connect(function()
        if not settings.autoaim then return end
        
        local character = player.Character
        if not character then return end
        
        local myRoot = character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local enemy = findClosestEnemy()
        if not enemy or not enemy.Character then 
            return 
        end
        
        local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
        if not enemyRoot then 
            return 
        end
        
        local distance = (myRoot.Position - enemyRoot.Position).Magnitude
        
        -- Обновляем трасер (виден через стены)
        updateAutoAimTracer()
        
        if distance <= autoAimDistance then
            local direction = (enemyRoot.Position - myRoot.Position)
            
            -- Определяем текущий режим
            local currentMode = autoAimMode
            if autoAimMode == "auto" then
                currentMode = getCameraMode()
            end
            
            -- Режим от первого лица (УСКОРЕННЫЙ)
            if currentMode == "firstperson" then
                local camera = Workspace.CurrentCamera
                if camera then
                    -- БЫСТРЫЙ поворот камеры к цели (без плавности)
                    camera.CFrame = CFrame.new(camera.CFrame.Position, enemyRoot.Position)
                end
            -- Режим от третьего лица (УСКОРЕННЫЙ)
            else
                -- Быстрый горизонтальный поворот гуманоида
                direction = Vector3.new(direction.X, 0, direction.Z)
                if direction.Magnitude > 0 then
                    direction = direction.Unit
                    local lookPoint = myRoot.Position + direction
                    myRoot.CFrame = CFrame.new(myRoot.Position, Vector3.new(lookPoint.X, myRoot.Position.Y, lookPoint.Z))
                end
            end
        end
    end)
end

local function stopAutoAim()
    if connections.autoaim then
        connections.autoaim:Disconnect()
        connections.autoaim = nil
    end
    
    if autoAimLine then
        autoAimLine:Destroy()
        autoAimLine = nil
    end
    
    print("[Auto Aim] ❌ Выключен")
end

-- ========== ТЕЛЕПОРТ ==========
local function teleportForward()
    local now = tick()
    
    if now - lastTeleportTime < teleportCooldown then
        return
    end
    
    lastTeleportTime = now
    
    local character = player.Character
    if not character then
        print("[Teleport] Нет персонажа")
        return
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        print("[Teleport] Нет HumanoidRootPart")
        return
    end
    
    -- Получаем направление взгляда камеры
    local camera = Workspace.CurrentCamera
    local lookVector = camera.CFrame.LookVector
    
    -- Убираем вертикальную составляющую для движения только вперед/назад
    local horizontalLookVector = Vector3.new(lookVector.X, 0, lookVector.Z)
    if horizontalLookVector.Magnitude > 0 then
        horizontalLookVector = horizontalLookVector.Unit
    else
        horizontalLookVector = Vector3.new(0, 0, 1) -- Направление по умолчанию
    end
    
    -- МГНОВЕННЫЙ телепорт вперед через стены
    local newPosition = humanoidRootPart.Position + (horizontalLookVector * teleportDistance)
    
    -- Временно отключаем коллизию для телепорта
    local originalCollision = {}
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            originalCollision[part] = part.CanCollide
            part.CanCollide = false
        end
    end
    
    -- Мгновенно телепортируем
    humanoidRootPart.CFrame = CFrame.new(newPosition)
    
    -- Ждем немного и восстанавливаем коллизию
    wait(0.05)
    for part, canCollide in pairs(originalCollision) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
    end
    
    -- Выводим сообщение
    print("[Teleport] Мгновенно телепортирован на " .. teleportDistance .. " studs вперед")
    
    -- Обновляем статус в интерфейсе
    if buttons.teleport and buttons.teleport.frame then
        local statusLabel = buttons.teleport.teleportStatusLabel
        if statusLabel then
            statusLabel.Text = "Телепортирован!"
            statusLabel.TextColor3 = Color3.fromRGB(0, 255, 200)
            
            delay(1, function()
                if statusLabel and settings.teleport then
                    statusLabel.Text = "Статус: Включено (Q)"
                    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                end
            end)
        end
    end
end

-- ========== ТЕЛЕПОРТ ВВЕРХ ==========
local function teleportUp(height)
    local character = player.Character
    if not character then
        print("[Jump Up] Нет персонажа")
        return
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        print("[Jump Up] Нет HumanoidRootPart")
        return
    end
    
    -- Отключаем коллизии
    local originalCollision = {}
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            originalCollision[part] = part.CanCollide
            part.CanCollide = false
        end
    end
    
    -- Мгновенный телепорт вверх (идентично teleportForward)
    local newPosition = humanoidRootPart.Position + Vector3.new(0, height, 0)
    humanoidRootPart.CFrame = CFrame.new(newPosition)
    
    -- Восстанавливаем коллизии асинхронно чтобы не блокировать телепорт
    task.spawn(function()
        task.wait(0.05)
        for part, canCollide in pairs(originalCollision) do
            if part and part.Parent then
                part.CanCollide = canCollide
            end
        end
    end)
    
    print("[Jump Up] Мгновенно телепортирован вверх на " .. height .. " studs")
end

