            print("🎯🏃‍♂️ Pursuit включено (F5)")
        else
            stopPursuit()
            buttons.pursuit.button.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            buttons.pursuit.button.Text = "OFF"
            print("🎯🏃‍♂️ Pursuit выключено (F5)")
        end
    end
    
    if input.KeyCode == Enum.KeyCode.F11 then
        autoAimDistance = math.max(10, autoAimDistance - 10)
        updateAutoAimDisplay()
        print("[Auto Aim] Быстрое уменьшение: " .. autoAimDistance .. " studs (F11)")
    end
    
    if input.KeyCode == Enum.KeyCode.F12 then
        autoAimDistance = math.min(500, autoAimDistance + 10)
        updateAutoAimDisplay()
        print("[Auto Aim] Быстрое увеличение: " .. autoAimDistance .. " studs (F12)")
    end
    
    if input.KeyCode == Enum.KeyCode.F6 then
        -- Быстрое переключение режимов Auto Aim
        switchAutoAimMode()
        print("[Auto Aim] Режим переключен на: " .. autoAimMode .. " (F6)")
    end
    
    if input.KeyCode == Enum.KeyCode.F7 then
        -- Быстрое уменьшение скорости
        speedHackValue = math.max(1, speedHackValue - 1)
        updateSpeedHackDisplay()
        print("[Speed Hack] Скорость уменьшена: " .. speedHackValue .. " (F7)")
        
        if settings.speed then
            updateSpeed()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.F8 then
        -- Быстрое увеличение скорости
        speedHackValue = math.min(200, speedHackValue + 1)
        updateSpeedHackDisplay()
        print("[Speed Hack] Скорость увеличена: " .. speedHackValue .. " (F8)")
        
        if settings.speed then
            updateSpeed()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.F9 then
        -- Быстрое включение/выключение телепорта
        settings.teleport = not settings.teleport
        if settings.teleport then
            startTeleport()
            buttons.teleport.button.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
            buttons.teleport.button.Text = "ON"
            print("🚀 Teleport включен (F9)")
        else
            stopTeleport()
            buttons.teleport.button.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
            buttons.teleport.button.Text = "OFF"
            print("🚀 Teleport выключен (F9)")
        end
    end
    
    if input.KeyCode == Enum.KeyCode.Q and settings.teleport then
        -- Телепорт по клавише Q
        teleportForward()
    end
end)

